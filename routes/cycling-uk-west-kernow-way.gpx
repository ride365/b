        <name>Divert</name>
        <desc>Cross Loe Bar to continue straight on, or follow bridleways round inlet to overnight in Helston</desc>
    </wpt>
    <wpt lat="50.0291331" lon="-5.2465082">
        <desc>Turn right to follow byway</desc>
    </wpt>
    <wpt lat="50.0025299" lon="-5.2525798">
