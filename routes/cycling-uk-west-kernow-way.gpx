    <wpt lat="50.1207752" lon="-5.5314084"/>
    <wpt lat="50.0992297" lon="-5.5434352">
        <desc>Stay left and join cycle track</desc>
    </wpt>
    <wpt lat="50.0890399" lon="-5.5340962">
        <desc>Penlee Lifeboat Station &amp; Memorial</desc>
    </wpt>
    <wpt lat="50.0677378" lon="-5.5732927">
        <desc>Turn left from NCN route and follow bridleway climb</desc>
    </wpt>
    <wpt lat="50.0627365" lon="-5.5983903">
        <name>Leave NCN Route 3</name>
        <desc>Head straight on instead of following NCN route to St Buryan</desc>
    </wpt>
    <wpt lat="50.0541829" lon="-5.6374520">
        <name>Caution</name>
        <desc>Caution, steep descent</desc>
    </wpt>
    <wpt lat="50.0517967" lon="-5.6420836">
        <name>Divert point</name>
        <desc>Follow bridleway route on left for rocky descent into Porthcurno</desc>
    </wpt>
    <wpt lat="50.0763218" lon="-5.6825747">
        <name>Rejoin NCN</name>
        <desc>Rejoin NCN route 3 to Land's End</desc>
    </wpt>
    <wpt lat="50.0771088" lon="-5.6851826">
        <name>Caution, Road Crossing</name>
        <desc>Cross A30 here and follow out and back route to Land's End</desc>
    </wpt>
    <wpt lat="50.0771881" lon="-5.6852574">
        <name>Caution A30</name>
        <desc>Join A30 for short distance - can be busy at times.</desc>
    </wpt>
    <wpt lat="50.0874066" lon="-5.6703361">
        <name>Leave A30</name>
        <desc>Break away from main road and ride past airport</desc>
    </wpt>
    <wpt lat="50.1158870" lon="-5.6876493">
        <name>Dismount</name>
        <desc>Dismount for short footpath (with believed historic higher rights) section out of courtesy to local residents.</desc>
    </wpt>
    <wpt lat="50.1214393" lon="-5.6983868">
        <name>Caution</name>
        <desc>Caution on steep rocky descent</desc>
    </wpt>
    <wpt lat="50.1319521" lon="-5.6891172">
        <name>Tin Coast - Be Nice, Say Hi.</name>
        <desc>Be aware of high visitor densities along this section of byway</desc>
    </wpt>
    <wpt lat="50.1406600" lon="-5.6455833">
        <name>Join Tinner's Way</name>
        <desc>Please see guidebook for explanation of historic evidence regards this section of trail, parts of which are recorded as footpath. </desc>
    </wpt>
    <wpt lat="50.1583975" lon="-5.6069634">
        <name>Ancient Sites</name>
        <desc>Men an Tol and Men Scryfa. plus other neolithic sites, along this section of route.</desc>
    </wpt>
    <wpt lat="50.1673747" lon="-5.5750285">
        <name>Divert</name>
        <desc>Divert south for Mulfra Hill and Chysauster ancient village</desc>
    </wpt>
    <wpt lat="50.1669437" lon="-5.4959644">
        <name>Divert if muddy</name>
        <desc>Bridleway to right is best route but may be impassable in winter - GPX route here diverts  here via road to pass below Trencrom Hill Fort.</desc>
    </wpt>
    <wpt lat="50.1667584" lon="-5.4534155">
        <name>Caution</name>
        <desc>Caution when crossing A30</desc>
    </wpt>
    <wpt lat="50.1501633" lon="-5.4026897">
        <name>SW 5703 3331</name>
        <desc>Go straight on towards Relubbus</desc>
    </wpt>
    <wpt lat="50.1214026" lon="-5.3640759">
        <name>Divert</name>
        <desc>Divert left onto Tregonning Hill FP option  as per guidebook </desc>
    </wpt>
    <wpt lat="50.1086657" lon="-5.3541063">
        <name>Caution</name>
        <desc>Caution crossing main road</desc>
    </wpt>
