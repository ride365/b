    </wpt>
    <wpt lat="50.1415604" lon="-5.4558541">
        <name>Byway Ends</name>
        <desc>Recorded extent of Byway  ends at parish boundary - route continues to public road over unrecorded section of highway</desc>
    </wpt>
    <wpt lat="50.1379464" lon="-5.4639245">
        <name>National Cycle Network</name>
        <desc>Follow NCN signs to Marazion
</desc>
