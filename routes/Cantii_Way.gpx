 <metadata>
  <name>Cantii Way</name>
  <author>
   <name>Cycling UK</name>
   <link href="https://www.cyclinguk.org/routes/long-distance/cantii-way"/>
  </author>
  <desc>Taking its name from the Celtic tribe which inhabited the area during the Iron Age, the Cantii Way combines quirky coastal towns and dramatic chalk cliffs with the rolling hills of the Kent Downs Area of Outstanding Natural Beauty.</desc>
  <link href="https://www.cyclinguk.org/routes/cantii-way-map-and-gpx"/>
 </metadata>
