        <name>Mining Trails</name>
        <desc>Follow mining trails signage to Portreath or for short cut option direct to Care Brea.</desc>
    </wpt>
    <wpt lat="50.2603269" lon="-5.2848580">
        <name>Footpath</name>
        <desc>Dismount to push up short steep climb (part of mining trails network)</desc>
